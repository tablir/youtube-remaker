# .env.example — goes to GitHub (no real keys!)
# Copy to .env and fill in your real values: cp .env.example .env

# ============================================
# AI APIs
# ============================================
CLAUDE_API_KEY=your_claude_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# Stock footage APIs
# ============================================
PEXELS_API_KEY=your_pexels_api_key_here
PIXABAY_API_KEY=your_pixabay_api_key_here
STORYBLOCKS_API_KEY=your_storyblocks_api_key_here

# ============================================
# YouTube
# ============================================
YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here

# ============================================
# n8n
# ============================================
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_strong_password_here
N8N_ENCRYPTION_KEY=your_random_32_char_string_here
N8N_HOST=your_domain_or_ip_here
N8N_PORT=5678

# ============================================
# PostgreSQL
# ============================================
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=your_strong_password_here

# ============================================
# Pipeline settings
# ============================================
PIPELINE_OUTPUT_DIR=/data/output
PIPELINE_CACHE_DIR=/data/cache
PIPELINE_TEMP_DIR=/data/temp
DEFAULT_VOICE=edge-tts
CLIPS_PER_SECOND=4
